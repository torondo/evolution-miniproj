# Plotting results

#### Plot 1: By starting frequency bins (Extinction Rate by Starting Frequency) 
```{r, echo=FALSE}
extinction_results$freq_bin <- ntile(extinction_results$f0, 10)

binned <- extinction_results %>%
  group_by(freq_bin) %>%
  summarise(obs  = (mean(observed)*100), exp  = (mean(expected)*100),
            .groups = "drop") %>%
  tidyr::pivot_longer(cols = c(obs, exp), names_to = "type", values_to = "extinction_rate")

plot1 <- ggplot(binned, aes(x = freq_bin, y = extinction_rate, colour = type)) +
  geom_line() +
  scale_colour_manual(values = c("obs" = "steelblue", "exp" = "red"), 
                      labels = c("obs" = "Observed", "exp" = "Neutral"), name = NULL) +
  labs(x = "Starting frequency bin", y = "Mean extinction rate (%)",   tag = "a)") +
  theme_classic(base_size = 18) +
  theme(axis.title = element_text(size = 18), axis.text = element_text(size = 16),
        legend.position = "inside", legend.position.inside = c(1.3, 0.2))
plot1
```

